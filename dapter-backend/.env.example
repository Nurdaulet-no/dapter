PORT=3000
POCKETBASE_URL=http://127.0.0.1:8090
# Optional. Public origin clients use to fetch uploaded files. Defaults to POCKETBASE_URL.
POCKETBASE_PUBLIC_URL=http://127.0.0.1:8090
AI_PROVIDER=xai
POCKETBASE_SUPERUSER_EMAIL=@gmail.com
POCKETBASE_SUPERUSER_PASSWORD=
XAI_API_KEY=
XAI_MODEL=grok-4.2
XAI_IMAGE_MODEL=grok-2-image-1212
MAX_UPLOAD_SIZE_BYTES=20971520
MAX_EXTRACTED_CHARS=200000
AI_PROVIDER_ATTEMPT_TIMEOUT_MS=600000
AI_STAGE_TIMEOUT_MS=900000
AI_IMAGE_TIMEOUT_MS=60000
AI_IMAGE_CONCURRENCY=4
AI_MAX_OUTPUT_TOKENS=2000000
# Comma-separated CORS allowlist (single source of truth)
FRONTEND_BASE_URLS=http://localhost:3001
